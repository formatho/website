# Stripe Configuration - Frontend
# Get these from https://dashboard.stripe.com/test/apikeys

# Test Mode (use these for development)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Production Mode (switch to these when going live)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here

# Price IDs - Pro Tier
# Create products in Stripe Dashboard and copy the price IDs
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=price_pro_monthly_test
VITE_STRIPE_PRO_YEARLY_PRICE_ID=price_pro_yearly_test

# Price IDs - Enterprise Tier
VITE_STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_enterprise_monthly_test
VITE_STRIPE_ENTERPRISE_YEARLY_PRICE_ID=price_enterprise_yearly_test

# API URL
VITE_API_URL=http://localhost:18765
